{
  "realm": "sqq",
  "enabled": true,
  "displayName": "Superquinquin (test)",
  "loginTheme": "surdeule",
  "internationalizationEnabled": true,
  "defaultLocale": "fr",
  "supportedLocales": ["fr"],
  "sslRequired": "external",
  "registrationAllowed": false,
  "resetPasswordAllowed": true,
  "rememberMe": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "clients": [
    {
      "clientId": "test-app",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": ["http://localhost:8080/*", "http://localhost:8088/*", "http://localhost:3000/*"],
      "webOrigins": ["*"]
    }
  ],
  "components": {
    "org.keycloak.storage.UserStorageProvider": [
      {
        "name": "odoo",
        "providerId": "odoo-user-storage",
        "subComponents": {},
        "config": {
          "odoo-url": ["http://localhost:8069"],
          "odoo-database": ["sqq"],
          "admin-login": ["admin"],
          "admin-password": ["admin"],
          "store-password": ["false"],
          "encryption-key": [""],
          "enabled": ["true"],
          "priority": ["0"],
          "fullSyncPeriod": ["3600"],
          "changedSyncPeriod": ["-1"],
          "cachePolicy": ["DEFAULT"]
        }
      }
    ]
  }
}